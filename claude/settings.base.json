{
  "model": "claude-fable-5[1m]",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -f CLAUDE.local.md && echo '--- CLAUDE.local.md ---' && cat CLAUDE.local.md || true"
          },
          {
            "type": "command",
            "command": "\"$HOME\"/dotfiles/claude/bin/settings-symlink-guard.sh",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "autoUpdatesChannel": "stable",
  "theme": "dark-daltonized",
  "skipAutoPermissionPrompt": true,
  "tui": "fullscreen"
}
